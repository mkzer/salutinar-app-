# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-very-long-random-secret

# Admin password hash — generate with:
# node -e "const b=require('bcryptjs'); console.log(b.hashSync('YOUR_PASSWORD', 10))"
ADMIN_PASSWORD_HASH=$2a$10$REPLACE_WITH_YOUR_GENERATED_HASH

# Frontend URL (update after Vercel deploy)
FRONTEND_URL=http://localhost:3000

# Server port
PORT=3001

# Node environment
NODE_ENV=development

# Email (Gmail)
ADMIN_EMAIL=mkzeranis@gmail.com
GMAIL_USER=mkzeranis@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
